OPENAI_API_KEY=
TAVILY_API_KEY=
MODEL_NAME=

OPENAI_BASE_URL=

# 视觉模型配置（用于图片理解，需支持 vision 的模型）
# 若与主模型相同服务商，只需填 VISION_MODEL_NAME 即可
VISION_MODEL_NAME=
VISION_BASE_URL=
VISION_API_KEY=

# 向量嵌入模型配置
# 若与主模型相同服务商，EMBEDDING_API_KEY 和 EMBEDDING_BASE_URL 可不填（自动复用 OPENAI_API_KEY / OPENAI_BASE_URL）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# 向量维度，需与数据库中 vector(n) 的 n 一致，默认 1024
# OpenAI text-embedding-3-small/large 支持自定义维度
# 若使用不支持 dimensions 参数的模型，留空即可
EMBEDDING_DIMENSIONS=1024

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=
